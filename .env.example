# ── Database ──
DATABASE_URL=postgresql+asyncpg://atlasnote:atlasnote@postgres:5432/atlasnote

# ── Authentication ──
# GitHub OAuth (Recommended - free, simple setup)
# Create at: https://github.com/settings/applications/new
# Homepage URL: http://localhost:3000
# Callback URL: http://localhost:3000/api/auth/github/callback
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# Google OAuth (optional alternative)
# Create at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
JWT_SECRET=change-me-to-a-random-secret-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# ── LLM — Chat Provider ──
# Options: openai, ollama
# "openai" works with OpenAI, Groq, and any OpenAI-compatible API
LLM_PROVIDER=ollama
CHAT_MODEL=llama3
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# Azure OpenAI (optional, overrides OpenAI if set)
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
# AZURE_OPENAI_API_KEY=your-azure-key

# ── LLM — Embedding Provider ──
# Defaults to chat provider if not set separately
# Useful when chat runs on Groq/OpenAI but embeddings on Ollama
EMBEDDING_PROVIDER=ollama
EMBEDDING_MODEL=nomic-embed-text
# EMBEDDING_OPENAI_API_KEY=   # defaults to OPENAI_API_KEY
# EMBEDDING_OPENAI_BASE_URL=  # defaults to OPENAI_BASE_URL
EMBEDDING_DIMENSIONS=768

# ── Ollama ──
OLLAMA_BASE_URL=http://ollama:11434

# ── App ──
CORS_ORIGINS=http://localhost:3000
MCP_API_KEY=your-mcp-api-key

# ── Frontend ──
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_GITHUB_CLIENT_ID=your-github-client-id
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change-me-nextauth-secret
